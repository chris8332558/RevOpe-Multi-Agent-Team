# ── LLM Provider ────────────────────────────────────────────
# Option A: Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Option B: Local vLLM (OpenAI-compatible endpoint)
# VLLM_API_BASE=http://localhost:8000
# VLLM_API_KEY=none                  # vLLM usually doesn't require auth

# ── Active model (change this one line to switch providers) ──
# Gemini examples:
#   gemini/gemini-2.0-flash
#   gemini/gemini-1.5-pro
# vLLM examples (your local model name):
#   openai/mistral-7b-instruct
#   openai/llama-3-8b-instruct
LLM_MODEL=gemini/gemini-2.0-flash

# ── Agno Agent OS UI ────────────────────────────────────────
AGNO_API_KEY=your_agno_api_key_here
